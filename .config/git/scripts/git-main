#!/bin/sh

set -eu

die() {
  printf 'git-main: %s\n' "$*" >&2
  exit 1
}

ensure_repo() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a Git repository"
}

detect_target_branch() {
  if [ "${1:-}" = "main" ] || [ "${1:-}" = "master" ]; then
    printf '%s\n' "$1"
    return 0
  fi

  if git show-ref --verify --quiet refs/heads/main; then
    printf '%s\n' main
    return 0
  fi

  if git show-ref --verify --quiet refs/heads/master; then
    printf '%s\n' master
    return 0
  fi

  die "neither main nor master exists"
}

find_other_worktree_for_branch() {
  branch=$1
  current_path=$(git rev-parse --show-toplevel)

  git worktree list --porcelain | awk -v target="refs/heads/$branch" -v current="$current_path" '
    function flush() {
      if (path != "" && branch_ref == target && path != current) {
        print path
        found = 1
        exit
      }
    }
    /^worktree / {
      flush()
      path = substr($0, 10)
      branch_ref = ""
      next
    }
    /^branch / {
      branch_ref = substr($0, 8)
      next
    }
    /^$/ {
      flush()
      path = ""
      branch_ref = ""
      next
    }
    END {
      if (!found) {
        flush()
      }
    }
  '
}

ensure_repo

target_branch=$(detect_target_branch "${1:-}")
other_worktree=$(find_other_worktree_for_branch "$target_branch" || true)

if [ -n "$other_worktree" ]; then
  printf 'git-main: %s is already checked out in %s\n' "$target_branch" "$other_worktree"
  printf '%s\n' "$other_worktree"
  exit 0
fi

git switch "$target_branch"
