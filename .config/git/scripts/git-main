#!/bin/sh

set -eu

die() {
  printf 'git-main: %s\n' "$*" >&2
  exit 1
}

ensure_repo() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a Git repository"
}

detect_target_branch() {
  if [ "${1:-}" = "main" ] || [ "${1:-}" = "master" ]; then
    printf '%s\n' "$1"
    return 0
  fi

  if git show-ref --verify --quiet refs/heads/main; then
    printf '%s\n' main
    return 0
  fi

  if git show-ref --verify --quiet refs/heads/master; then
    printf '%s\n' master
    return 0
  fi

  die "neither main nor master exists"
}

find_repo_root_worktree() {
  git worktree list --porcelain | awk '
    /^worktree / {
      print substr($0, 10)
      exit
    }
  '
}

ensure_repo

target_branch=$(detect_target_branch "${1:-}")
repo_root_worktree=$(find_repo_root_worktree)

[ -n "$repo_root_worktree" ] || die "unable to determine the repo root worktree"

repo_root_branch=$(git -C "$repo_root_worktree" branch --show-current)

if [ "$repo_root_branch" != "$target_branch" ]; then
  git -C "$repo_root_worktree" switch "$target_branch"
fi

printf '%s\n' "$repo_root_worktree"
