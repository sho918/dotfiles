{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "soft_wrap": "editor_width",
  "git_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true
    }
  },
  "vim": {
    "use_smartcase_find": true
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "ui_font_family": "UDEV Gothic 35NF",
  "buffer_line_height": "comfortable",
  "buffer_font_family": "UDEV Gothic 35NF",
  "restore_on_startup": "empty_tab",
  "which_key": {
    "enabled": true
  },
  "autosave": "on_focus_change",
  "terminal": {
    "font_family": "UDEV Gothic 35NF"
  },
  "session": {
    "trust_all_worktrees": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": true,
  "icon_theme": "Catppuccin Frappé",
  "ui_font_size": 13.0,
  "buffer_font_size": 13.0,
  "theme": "Ayu Dark"
}
